{
  "name": "slideflipper",
  "productName": "SlideFlipper",
  "version": "1.0.2",
  "description": "Use your Amazfit watch as a presentation remote",
  "main": "main.js",
  "author": "Zephan",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.zephan.slideflipper",
    "productName": "SlideFlipper",
    "copyright": "Copyright © 2026 Zephan",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "artifactName": "SlideFlipper-Mac-${arch}.${ext}",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "SlideFlipper",
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "SlideFlipper-Windows-x64.${ext}",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
